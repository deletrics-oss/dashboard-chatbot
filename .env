# Configurações do Dashboard ChatBot - Versão Otimizada

# Ambiente
NODE_ENV=production

# Timeouts (em milissegundos)
INIT_TIMEOUT=180000
AUTH_TIMEOUT=240000
QR_TIMEOUT=90000
RECONNECT_TIMEOUT=45000
KEEPALIVE_INTERVAL=30000
HEALTH_CHECK_INTERVAL=60000

# Limites
MAX_CLIENTS=10
MAX_LOGS=1000
MAX_RECONNECT_ATTEMPTS=5
MEMORY_THRESHOLD=800

# Puppeteer
PUPPETEER_TIMEOUT=180000
PUPPETEER_SLOWMO=250

# Servidor
PORT=3000

# Configurações de Estabilidade
ENABLE_KEEP_ALIVE=true
ENABLE_AUTO_RECONNECT=true
ENABLE_HEALTH_CHECK=true

